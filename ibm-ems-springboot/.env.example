# IBM EMS - Environment Variables
# Copy: cp .env.example .env   then fill in values

SERVER_PORT=8080

# Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_KEY_MIN_32_CHARS
JWT_EXPIRATION_MS=3600000

SPRING_PROFILES_ACTIVE=dev

# Database (H2 defaults for dev)
DB_URL=jdbc:h2:mem:emsdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DB_DRIVER=org.h2.Driver
DB_USER=sa
DB_PASSWORD=

# MySQL (for production)
# DB_URL=jdbc:mysql://mysql:3306/emsdb?useSSL=true
# DB_DRIVER=com.mysql.cj.jdbc.Driver
# DB_USER=emsuser
# DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# DB_ROOT_PASSWORD=REPLACE_WITH_ROOT_PASSWORD
